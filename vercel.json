{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://smart-circle-production.up.railway.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://smart-circle-production.up.railway.app/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads|assets|favicon.ico).*务*)",
      "destination": "/index.html"
    }
  ]
}
