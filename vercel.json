{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_RENDER_BACKEND_URL.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://YOUR_RENDER_BACKEND_URL.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads|assets|favicon.ico).*务*)",
      "destination": "/index.html"
    }
  ]
}
